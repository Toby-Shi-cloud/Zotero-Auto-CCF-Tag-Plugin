{
  "name": "zotero-auto-ccf-tag-plugin",
  "type": "module",
  "version": "0.0.1",
  "description": "Zotero Auto CCF Tag Plugin",
  "config": {
    "addonName": "Zotero Auto CCF Tag Plugin",
    "addonID": "zoteroautoccftagplugin@tobyshi.com",
    "addonRef": "autoccftag",
    "addonInstance": "AutoCcfTag",
    "prefsPrefix": "extensions.zotero.autoccftag"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Toby-Shi-cloud/Zotero-Auto-CCF-Tag-Plugin.git"
  },
  "author": "Toby Shi",
  "bugs": {
    "url": "https://github.com/Toby-Shi-cloud/Zotero-Auto-CCF-Tag-Plugin/issues"
  },
  "homepage": "https://github.com/Toby-Shi-cloud/Zotero-Auto-CCF-Tag-Plugin#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^10.2.0",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^6.0.2",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
